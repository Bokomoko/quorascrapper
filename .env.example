# Shared / subscriber (.env.container)
# On bokomint (containers use host networking): Kafka on same machine
# KAFKA_BOOTSTRAP=127.0.0.1:19092
# From Mac/laptop preflight only: KAFKA_BOOTSTRAP=bokomint.local:19092
KAFKA_BOOTSTRAP=bokomint.local:19092
KAFKA_TOPIC=quora-answers
KAFKA_GROUP_ID=quora-consumer-group

# MongoDB Atlas — copy a fresh connection string from Atlas Connect
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=quora_data
MONGODB_COLLECTION=answers

# Scraper (.env.scraper) — also loaded by preflight
PROFILE_URL=https://pt.quora.com/profile/<USER>/answers
SENDER=stdout
MAX_RESULTS=200
SCROLL_PAUSE=1.5
# Linux container: /usr/bin/chromium
# macOS local dev: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Leave empty to auto-detect on macOS
CHROME_BINARY=

# Logging
LOG_LEVEL=INFO

# qsbk serve — extension default is http://bokomint.local:8765 (see extension/config.json)
# Override at install: qsbk install --serve-url http://bokomint.local:8765

# Global install (uv tool install): copy to ~/.config/qsbk/env
#   qsbk config copy /path/to/.env.container
# Or set: export QSBK_ENV=/path/to/your/env
