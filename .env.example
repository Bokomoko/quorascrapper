# Environment variables for Kafka-MongoDB Subscriber

# Kafka Configuration
KAFKA_BOOTSTRAP=bokomint.local:19092
KAFKA_TOPIC=quora-answers
KAFKA_GROUP_ID=quora-consumer-group

# MongoDB Atlas Configuration
# Get this from your MongoDB Atlas cluster: Connect > Connect your application > Copy connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=quora_data
MONGODB_COLLECTION=answers

# Logging
LOG_LEVEL=INFO
